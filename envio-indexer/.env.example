MANTLE_CHAIN_ID=5000
MANTLE_RPC_URL=https://rpc.mantle.xyz
START_BLOCK=96223050
IDENTITY_ADDRESS=0x...
REPUTATION_ADDRESS=0x...
VALIDATION_ADDRESS=0x...
SKILL_REGISTRY_ADDRESS=0x...
JOB_REGISTRY_ADDRESS=0x...
WALLET_FACTORY_ADDRESS=0x...

# Railway Postgres can provide DATABASE_URL. The indexer service wrapper maps
# it into ENVIO_PG_* for Envio and for the bundled GraphQL read API.
DATABASE_URL=
ENVIO_PG_HOST=
ENVIO_PG_PORT=5432
ENVIO_PG_USER=
ENVIO_PG_PASSWORD=
ENVIO_PG_DATABASE=
ENVIO_PG_SSL_MODE=require
ENVIO_HASURA=false
ENVIO_INDEXER_PORT=9898
INDEXER_API_MAX_FIRST=100
